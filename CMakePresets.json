{
	"version": 4,
	"configurePresets": [
		{
			"name": "debug",
			"binaryDir": "${sourceDir}/build",
			"cacheVariables": {
				"CMAKE_EXPORT_COMPILE_COMMANDS": "on",
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "default",
			"binaryDir": "${sourceDir}/build"
		},

		{
			"name": "android-base",
			"hidden": true,
			"binaryDir": "${sourceDir}/build-android",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"ANDROID_ABI": "arm64-v8a",
				"ANDROID_PLATFORM": "android-26"
			}
		}

	]
}
